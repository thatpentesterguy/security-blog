---
import { SITE } from '../config';
import { localizedPath, withBase } from '../i18n/utils';
import type { SeoMeta } from '../utils/seo';

interface Props {
  meta: SeoMeta;
}

const { meta } = Astro.props;

const author = {
  '@type': 'Person',
  name: SITE.author.name,
  url: SITE.url,
  jobTitle: 'Head of Cloud, Infrastructure & AI Security',
  sameAs: [
    'https://github.com/thatpentesterguy',
    'https://x.com/atulkjaiswal',
    'https://www.linkedin.com/in/atulkishorjaiswal',
  ],
};

const jsonLd =
  meta.type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: meta.title,
        description: meta.description,
        url: meta.canonical,
        image: meta.ogImage,
        datePublished: meta.publishedTime,
        dateModified: meta.modifiedTime ?? meta.publishedTime,
        keywords: meta.tags?.join(', '),
        author,
        publisher: {
          '@type': 'Organization',
          name: SITE.title,
          url: SITE.url,
        },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE.title,
        description: SITE.description,
        url: SITE.url,
        author,
      };

// Feed auto-discovery — feed readers and browser extensions look for
// these <link rel="alternate"> tags in <head>. We advertise the active
// locale's feed as the primary one, and (when multilingual) every other
// locale's feed too.
const primaryFeed = {
  href: localizedPath('/rss.xml', meta.locale),
  title: `${SITE.title}${meta.locale === 'fr' ? ' (FR)' : ''} — RSS`,
};
const otherFeeds = SITE.multilingual
  ? SITE.locales
      .filter((l) => l !== meta.locale)
      .map((l) => ({
        href: localizedPath('/rss.xml', l),
        title: `${SITE.title}${l === 'fr' ? ' (FR)' : ''} — RSS`,
      }))
  : [];
const sitemapHref = withBase('/sitemap-index.xml');
---

<title>{meta.title}</title>
<meta name="description" content={meta.description} />
<link rel="canonical" href={meta.canonical} />
{meta.noindex && <meta name="robots" content="noindex, nofollow" />}

{/* Feed + sitemap auto-discovery */}
<link
  rel="alternate"
  type="application/rss+xml"
  title={primaryFeed.title}
  href={primaryFeed.href}
/>
{
  otherFeeds.map((f) => (
    <link rel="alternate" type="application/rss+xml" title={f.title} href={f.href} />
  ))
}
<link rel="sitemap" type="application/xml" href={sitemapHref} />

{/* Open Graph */}
<meta property="og:site_name" content={SITE.title} />
<meta property="og:title" content={meta.title} />
<meta property="og:description" content={meta.description} />
<meta property="og:type" content={meta.type} />
<meta property="og:url" content={meta.canonical} />
<meta property="og:image" content={meta.ogImage} />
<meta property="og:locale" content={meta.locale === 'fr' ? 'fr_FR' : 'en_US'} />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@atulkjaiswal" />
<meta name="twitter:title" content={meta.title} />
<meta name="twitter:description" content={meta.description} />
<meta name="twitter:image" content={meta.ogImage} />

{/* Article-specific */}
{
  meta.type === 'article' && meta.publishedTime && (
    <meta property="article:published_time" content={meta.publishedTime} />
  )
}
{
  meta.type === 'article' && meta.modifiedTime && (
    <meta property="article:modified_time" content={meta.modifiedTime} />
  )
}
{meta.type === 'article' && meta.tags?.map((tag) => <meta property="article:tag" content={tag} />)}

{/* hreflang alternates for SEO */}
{
  SITE.multilingual &&
    meta.hreflangs.map(({ locale, href }) => <link rel="alternate" hreflang={locale} href={href} />)
}

{/* JSON-LD Structured Data */}
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
