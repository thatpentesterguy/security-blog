---
/**
 * Fetches the Cloudflare Web Analytics page-view count for the current post
 * (via /api/views) and renders it inline alongside the date / reading-time
 * metadata strip.
 */
import { Icon } from 'astro-icon/components';

interface Props {
  /** The page path Web Analytics recorded, e.g. /posts/my-post */
  path: string;
}

const { path } = Astro.props;
---

<span class="inline-flex items-center gap-1" data-vc-path={path}>
  <Icon name="lucide:eye" width={14} height={14} />
  <span data-vc-count>—</span>
</span>

<script>
  function countViews() {
    document.querySelectorAll<HTMLElement>('[data-vc-path]').forEach(async (el) => {
      // Guard so the optimistic re-runs (initial call + astro:page-load) can't
      // process the same element twice. Set synchronously, before any await,
      // so there's no race that could double-POST.
      if (el.dataset.vcInit === '1') return;
      el.dataset.vcInit = '1';

      const path = el.getAttribute('data-vc-path');
      if (!path) return;

      // Count one view per browser session per path; on later visits within the
      // same session just read the total. This is what filters refresh-spam, and
      // since it runs in JS it also skips most non-rendering bots.
      const seenKey = `vc:${path}`;
      let counted = false;
      try {
        counted = sessionStorage.getItem(seenKey) === '1';
      } catch {
        // sessionStorage unavailable (private mode / blocked) — fall back to read.
      }

      try {
        const res = counted
          ? await fetch(`/api/views?path=${encodeURIComponent(path)}`)
          : await fetch('/api/views', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ path }),
            });
        if (!res.ok) return;

        if (!counted) {
          try {
            sessionStorage.setItem(seenKey, '1');
          } catch {
            /* ignore */
          }
        }

        const { count } = await res.json();
        if (!count) return;
        const countEl = el.querySelector('[data-vc-count]');
        if (countEl) countEl.textContent = count;
      } catch {
        // Silently fail — no count shown if the API is unreachable.
      }
    });
  }

  // Run on first load and after every Astro view transition, so posts reached
  // via in-site navigation (client-side swap) get counted too — not just full
  // page loads. The per-element guard above keeps it idempotent.
  document.addEventListener('astro:page-load', countViews);
  countViews();
</script>
