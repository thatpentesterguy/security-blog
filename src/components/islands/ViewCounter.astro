---
/**
 * Fetches the GoatCounter page-view count for the current post and renders it
 * inline alongside the date / reading-time metadata strip.
 */
import { Icon } from 'astro-icon/components';

interface Props {
  /** The page path that GoatCounter recorded, e.g. /posts/my-post */
  path: string;
}

const { path } = Astro.props;
---

<span class="inline-flex items-center gap-1" data-vc-path={path}>
  <Icon name="lucide:eye" width={14} height={14} />
  <span data-vc-count>—</span>
</span>

<script>
  document.querySelectorAll<HTMLElement>('[data-vc-path]').forEach(async (el) => {
    const path = el.getAttribute('data-vc-path');
    if (!path) return;
    try {
      const res = await fetch(
        `https://thatpentesterguy.goatcounter.com/counter/${encodeURIComponent(path)}.json`,
      );
      if (!res.ok) return;
      const { count } = await res.json();
      const countEl = el.querySelector('[data-vc-count]');
      if (countEl) countEl.textContent = count;
    } catch {
      // Silently fail — no count shown if GoatCounter is unreachable
    }
  });
</script>
